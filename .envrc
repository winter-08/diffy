use flake

source_env_if_exists .envrc.local

export DIFFY_REPO_ROOT="${DIFFY_REPO_ROOT:-$PWD}"
export PHOSPHOR_PACK_INDEX_PUBLIC_KEY="${PHOSPHOR_PACK_INDEX_PUBLIC_KEY:-1f3d2cb98f99da0321bdfa8549b4a43a36f96d7e25b710fb49739d46065b19f1}"
export DIFFY_CODESIGN_IDENTITY="${DIFFY_CODESIGN_IDENTITY:-Diffy Dev}"

if [ -z "${DIFFY_ENABLE_KEYRING:-}" ] && [ -z "${DIFFY_DISABLE_KEYRING:-}" ]; then
  export DIFFY_DISABLE_KEYRING=1
fi
